#!/usr/bin/env bash
set -euo pipefail

MULTI=0
if [[ "${1:-}" == "--multi" ]]; then
    MULTI=1
fi

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "Error: required command not found: $1" >&2
        exit 1
    }
}

require_cmd tmux
require_cmd fzf

pane_path="$(tmux display-message -p "#{pane_current_path}")"
session="$(tmux display-message -p "#{session_name}")"

PMUX_LOOM_FZF_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/loom/generated/fzf-theme.sh"
PMUX_FZF_BASE_OPTS="${PMUX_FZF_BASE_OPTS:-}"

load_fzf_theme() {
    LOOM_FZF_COLOR_OPTS=""
    if [[ -f "${PMUX_LOOM_FZF_FILE}" ]]; then
        # shellcheck source=/dev/null
        source "${PMUX_LOOM_FZF_FILE}"
    fi
}

current_fzf_opts() {
    load_fzf_theme
    printf '%s' "${PMUX_FZF_BASE_OPTS:+$PMUX_FZF_BASE_OPTS }${LOOM_FZF_COLOR_OPTS:-}"
}

window_name_from_cmd() {
    local cmd="$1"
    # Strip leading tool prefix to get a short, readable window name
    cmd="${cmd#make }"
    cmd="${cmd#npm run }"
    cmd="${cmd#cargo }"
    cmd="${cmd#go }"
    cmd="${cmd#python -m }"
    cmd="${cmd#docker compose -f }"
    cmd="${cmd#docker }"
    # Truncate long names
    printf '%s' "${cmd:0:30}"
}

create_run_window() {
    local name="$1"
    tmux new-window -t "$session:" -n "$name" -c "$pane_path" -P -F "#{window_id}"
}

has_file() {
    [[ -f "$pane_path/$1" ]]
}

has_any() {
    local f
    for f in "$@"; do
        [[ -f "$pane_path/$f" ]] && return 0
    done
    return 1
}

make_targets() {
    has_file "Makefile" || return 0
    awk -F: '
        /^[a-zA-Z0-9_.-]+:/ && $1 !~ /^(\.|%)/ {
            t=$1
            if (t != "PHONY") print t
        }
    ' "$pane_path/Makefile" | sort -u
}

compose_files() {
    local out=()

    local f
    for f in "compose.yml" "docker-compose.yml"; do
        [[ -f "$pane_path/$f" ]] && out+=("$f")
    done

    while IFS= read -r f; do
        out+=("$f")
    done < <(find "$pane_path" -maxdepth 1 -type f \( -name 'docker-compose.*.yml' -o -name 'compose.*.yml' \) -printf '%f\n' 2>/dev/null | sort -u)

    printf '%s\n' "${out[@]}" | awk 'NF' | sort -u
}

dockerfile_present() {
    has_any "Dockerfile" "Dockerfile.dev" "Dockerfile.local"
}

pkg_scripts() {
    has_file "package.json" || return 0
    command -v jq >/dev/null 2>&1 || return 0
    jq -r '.scripts // {} | keys[]' "$pane_path/package.json" 2>/dev/null | awk 'NF' | sort
}

make_target_priority() {
    case "$1" in
        dev) echo "00:$1" ;;
        up) echo "01:$1" ;;
        run) echo "02:$1" ;;
        start) echo "03:$1" ;;
        test) echo "04:$1" ;;
        *) echo "50:$1" ;;
    esac
}

build_menu() {
    local items=()

    if has_file "Makefile"; then
        while IFS= read -r t; do
            items+=("make $t")
        done < <(make_targets | awk 'NF' | while read -r t; do make_target_priority "$t"; done | sort | cut -d: -f2-)
    fi

    local cfiles=()
    while IFS= read -r f; do
        [[ -n "$f" ]] && cfiles+=("$f")
    done < <(compose_files)

    if [[ "${#cfiles[@]}" -gt 0 ]]; then
        local f
        for f in "${cfiles[@]}"; do
            items+=("docker compose -f $f up")
            items+=("docker compose -f $f up --build")
            items+=("docker compose -f $f down")
        done
    fi

    if dockerfile_present; then
        items+=("docker build -t $(basename "$pane_path") .")
    fi

    if has_file "package.json"; then
        if command -v jq >/dev/null 2>&1; then
            while IFS= read -r s; do
                items+=("npm run $s")
            done < <(pkg_scripts)
        else
            items+=("npm run dev")
            items+=("npm start")
        fi
    fi

    if has_file "go.mod"; then
        items+=("go test ./... -count=1")
        items+=("go test ./...")
        items+=("go run .")
    fi

    if has_file "Cargo.toml"; then
        items+=("cargo run")
        items+=("cargo test")
    fi

    if has_any "pyproject.toml" "requirements.txt"; then
        items+=("python -m pytest")
    fi

    printf '%s\n' "${items[@]}" | awk 'NF' | sort -u
}

pick_commands() {
    local menu
    local fzf_opts

    menu="$(build_menu)"
    [[ -n "$menu" ]] || menu="echo 'No detected commands. Type what you want.'"

    fzf_opts="$(current_fzf_opts)"

    if [[ "$MULTI" -eq 1 ]]; then
        printf '%s\n' "$menu" | env -u FZF_DEFAULT_OPTS FZF_DEFAULT_OPTS="$fzf_opts" fzf -m --prompt="run (multi)> "
    else
        printf '%s\n' "$menu" | env -u FZF_DEFAULT_OPTS FZF_DEFAULT_OPTS="$fzf_opts" fzf --prompt="run> "
    fi
}

run_single() {
    local cmd="$1"
    local name
    name="$(window_name_from_cmd "$cmd")"
    local wid
    wid="$(create_run_window "$name")"
    tmux select-window -t "$wid"
    tmux send-keys -t "$wid" "cd \"$pane_path\" && $cmd" C-m
}

run_multi() {
    local wid
    wid="$(create_run_window "run")"
    tmux select-window -t "$wid"

    local first=1
    local idx=0
    local cmd

    while IFS= read -r cmd; do
        [[ -n "$cmd" ]] || continue

        if [[ "$first" -eq 1 ]]; then
            tmux select-pane -t "$wid".0
            tmux send-keys -t "$wid".0 "cd \"$pane_path\" && $cmd" C-m
            first=0
        else
            tmux split-window -t "$wid" -v -c "$pane_path"
            idx=$((idx + 1))
            tmux send-keys -t "$wid".$idx "cd \"$pane_path\" && $cmd" C-m
        fi
    done

    tmux select-layout -t "$wid" tiled >/dev/null 2>&1 || true
}

selected="$(pick_commands || true)"
[[ -n "${selected:-}" ]] || exit 0

if [[ "$MULTI" -eq 1 ]]; then
    run_multi <<< "$selected"
else
    run_single "$selected"
fi
