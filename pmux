#!/usr/bin/env bash
set -euo pipefail

PMUX_VERSION="0.2.0"

PMUX_CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/pmux/config"

PMUX_EDITOR_CMD='exec nvim .'
PMUX_SHELL_CMD='exec "$SHELL" -l'
PMUX_CHOOSER_CMD='fzf --prompt="Project > "'

PMUX_DOTFILES_DIR="${HOME}/.dotfiles"
PMUX_REPOS_DIR="${HOME}/repos"

PMUX_FIXED_PROJECTS_DEFAULT=("${PMUX_DOTFILES_DIR}")
PMUX_PROJECT_ROOTS_DEFAULT=("${PMUX_REPOS_DIR}")

load_config() {
    if [[ -f "${PMUX_CONFIG_FILE}" ]]; then
        # shellcheck source=/dev/null
        source "${PMUX_CONFIG_FILE}"
    fi

    if ! declare -p PMUX_FIXED_PROJECTS >/dev/null 2>&1; then
        PMUX_FIXED_PROJECTS=("${PMUX_FIXED_PROJECTS_DEFAULT[@]}")
    fi

    if ! declare -p PMUX_PROJECT_ROOTS >/dev/null 2>&1; then
        PMUX_PROJECT_ROOTS=("${PMUX_PROJECT_ROOTS_DEFAULT[@]}")
    fi
}

usage() {
cat <<EOF
pmux - project multiplexer for tmux

Usage:
  pmux
  pmux <project-path>
  pmux --help
  pmux --version

Examples:
  pmux
  pmux ~/repos/myapp
EOF
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "Error: required command not found: $1" >&2
        exit 1
    }
}

resolve_dir() {
    local p="$1"

    if [[ -d "$p" ]]; then
        cd "$p" >/dev/null && pwd -P
        return
    fi

    if [[ -L "$p" ]]; then
        local r
        r="$(readlink -f "$p" 2>/dev/null || true)"
        [[ -n "$r" && -d "$r" ]] && cd "$r" >/dev/null && pwd -P && return
    fi

    return 1
}

emit_project_if_valid() {
    local r
    r="$(resolve_dir "$1" || true)"
    [[ -n "$r" ]] && echo "$r"
}

build_choices() {
    local p root child

    for p in "${PMUX_FIXED_PROJECTS[@]}"; do
        emit_project_if_valid "$p"
    done

    for root in "${PMUX_PROJECT_ROOTS[@]}"; do
        [[ -d "$root" ]] || continue
        while IFS= read -r child; do
            emit_project_if_valid "$child"
        done < <(find "$root" -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -print 2>/dev/null | sort)
    done
}

choose_project() {
    build_choices | awk '!seen[$0]++' | eval "$PMUX_CHOOSER_CMD"
}

find_launch_script() {
    [[ -f "$1/.pmux/launch.sh" ]] && echo "$1/.pmux/launch.sh"
}

find_subprojects_file() {
    [[ -f "$1/.pmux/subprojects" ]] && echo "$1/.pmux/subprojects"
}

find_python_venv_in_dir() {
    local c
    for c in .venv venv env; do
        [[ -f "$1/$c/bin/activate" ]] && echo "$1/$c" && return
    done
}

find_nearest_python_venv() {
    local cur="$1"
    local stop="$2"

    while true; do
        local v
        v="$(find_python_venv_in_dir "$cur" || true)"
        [[ -n "$v" ]] && echo "$v" && return

        [[ "$cur" == "$stop" ]] && break
        cur="$(dirname "$cur")"
    done
}

find_nvmrc_in_dir() {
    [[ -f "$1/.nvmrc" ]] && echo "$1/.nvmrc"
}

find_nearest_nvmrc() {
    local cur="$1"
    local stop="$2"

    while true; do
        local n
        n="$(find_nvmrc_in_dir "$cur" || true)"
        [[ -n "$n" ]] && echo "$n" && return

        [[ "$cur" == "$stop" ]] && break
        cur="$(dirname "$cur")"
    done
}

sanitize_name() {
    printf '%s' "$1" | tr '. /' '___' | tr -cd '[:alnum:]_-'
}

build_shell_prefix() {
    local venv="$1"
    local nvmrc="$2"

    local p='cd "$1"'

    if [[ -n "$venv" ]]; then
        p+='; source "$2/bin/activate"'
    fi

    if [[ -n "$nvmrc" ]]; then
        p+='; export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"'
        p+='; [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh" && nvm use >/dev/null || true'
    fi

    printf '%s' "$p"
}

run_in_window() {
    local session="$1"
    local window_name="$2"
    local dir="$3"
    local root="$4"
    local cmd="$5"

    local venv
    venv="$(find_nearest_python_venv "$dir" "$root" || true)"

    local nvmrc
    nvmrc="$(find_nearest_nvmrc "$dir" "$root" || true)"

    local prefix
    prefix="$(build_shell_prefix "$venv" "$nvmrc")"

    tmux new-window -t "$session:" -n "$window_name" -c "$dir" \
        bash -lc "$prefix; $cmd" bash "$dir" "$venv"
}

create_leaf_session() {
    local session="$1"
    local root="$2"
    local launch="$3"

    local venv
    venv="$(find_nearest_python_venv "$root" "$root" || true)"

    local nvmrc
    nvmrc="$(find_nearest_nvmrc "$root" "$root" || true)"

    local prefix
    prefix="$(build_shell_prefix "$venv" "$nvmrc")"

    tmux new-session -d -s "$session" -n editor -c "$root" \
        bash -lc "$prefix; $PMUX_EDITOR_CMD" bash "$root" "$venv"

    tmux new-window -t "$session:" -n shell -c "$root" \
        bash -lc "$prefix; $PMUX_SHELL_CMD" bash "$root" "$venv"

    if [[ -n "$launch" ]]; then
        tmux new-window -t "$session:" -n run -c "$root" \
            bash -lc "$prefix; bash ./.pmux/launch.sh; $PMUX_SHELL_CMD"
    fi

    tmux select-window -t "$session:editor"
}

create_container_session() {
    local session="$1"
    local root="$2"
    local subs_file="$3"
    local launch="$4"

    local first_window=""
    local first=1

    while IFS= read -r rel || [[ -n "$rel" ]]; do
        rel="$(printf '%s' "$rel" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
        [[ -z "$rel" || "$rel" == \#* ]] && continue
        [[ -d "$root/$rel" ]] || continue

        local window_name
        window_name="$(sanitize_name "$rel")"

        if [[ "$first" -eq 1 ]]; then
            local venv
            venv="$(find_nearest_python_venv "$root/$rel" "$root" || true)"

            local nvmrc
            nvmrc="$(find_nearest_nvmrc "$root/$rel" "$root" || true)"

            local prefix
            prefix="$(build_shell_prefix "$venv" "$nvmrc")"

            tmux new-session -d -s "$session" -n "$window_name" -c "$root/$rel" \
                bash -lc "$prefix; $PMUX_EDITOR_CMD" bash "$root/$rel" "$venv"

            first_window="$window_name"
            first=0
        else
            run_in_window \
                "$session" \
                "$window_name" \
                "$root/$rel" \
                "$root" \
                "$PMUX_EDITOR_CMD"
        fi
    done < "$subs_file"

    if [[ -z "$first_window" ]]; then
        echo "Error: .pmux/subprojects exists, but no valid subproject directories were found." >&2
        exit 1
    fi

    run_in_window \
        "$session" \
        "shell" \
        "$root" \
        "$root" \
        "$PMUX_SHELL_CMD"

    if [[ -n "$launch" ]]; then
        run_in_window \
            "$session" \
            "run" \
            "$root" \
            "$root" \
            'bash ./.pmux/launch.sh; exec "$SHELL" -l'
    fi

    tmux select-window -t "$session:$first_window"
}

main() {
    load_config

    case "${1:-}" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            echo "$PMUX_VERSION"
            exit 0
            ;;
    esac

    require_cmd tmux
    require_cmd bash

    local selected
    if [[ $# -eq 1 ]]; then
        selected="$1"
    else
        require_cmd fzf
        selected="$(choose_project || true)"
    fi

    [[ -n "$selected" ]] || exit 0

    local root
    root="$(resolve_dir "$selected")"

    local session
    session="$(sanitize_name "$(basename "$root")")"

    local launch
    launch="$(find_launch_script "$root" || true)"

    local subs
    subs="$(find_subprojects_file "$root" || true)"

    if ! tmux has-session -t "$session" 2>/dev/null; then
        if [[ -n "$subs" ]]; then
            create_container_session "$session" "$root" "$subs" "$launch"
        else
            create_leaf_session "$session" "$root" "$launch"
        fi
    fi

    if [[ -z "${TMUX:-}" ]]; then
        exec tmux attach-session -t "$session"
    else
        exec tmux switch-client -t "$session"
    fi
}

main "$@"
