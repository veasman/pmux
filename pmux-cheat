#!/usr/bin/env bash
set -euo pipefail

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "Error: required command not found: $1" >&2
        exit 1
    }
}

require_cmd tmux
require_cmd fzf
require_cmd curl

CHEAT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pmux/cheat"
LANG_FILE="$CHEAT_DIR/languages"
CMD_FILE="$CHEAT_DIR/commands"

PMUX_LOOM_FZF_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/loom/generated/fzf-theme.sh"
PMUX_FZF_BASE_OPTS="${PMUX_FZF_BASE_OPTS:-}"

load_fzf_theme() {
    LOOM_FZF_COLOR_OPTS=""
    if [[ -f "${PMUX_LOOM_FZF_FILE}" ]]; then
        # shellcheck source=/dev/null
        source "${PMUX_LOOM_FZF_FILE}"
    fi
}

current_fzf_opts() {
    load_fzf_theme
    printf '%s' "${PMUX_FZF_BASE_OPTS:+$PMUX_FZF_BASE_OPTS }${LOOM_FZF_COLOR_OPTS:-}"
}

[[ -f "$LANG_FILE" ]] || {
    echo "Error: missing $LANG_FILE" >&2
    exit 1
}

[[ -f "$CMD_FILE" ]] || {
    echo "Error: missing $CMD_FILE" >&2
    exit 1
}

selected="$(cat "$LANG_FILE" "$CMD_FILE" | awk 'NF' | env -u FZF_DEFAULT_OPTS FZF_DEFAULT_OPTS="$(current_fzf_opts)" fzf --prompt="cheat> " || true)"
[[ -n "${selected:-}" ]] || exit 0

read -r -p "Enter Query: " query
[[ -n "${query:-}" ]] || exit 0

if grep -qsx "$selected" "$LANG_FILE"; then
    query="$(printf '%s' "$query" | tr ' ' '+')"
    tmux new-window -n "cheat:$selected" \
        "sh -lc 'echo \"curl cht.sh/$selected/$query\"; echo; curl -s \"cht.sh/$selected/$query\"; exec sh'"
else
    tmux new-window -n "cheat:$selected" \
        "sh -lc 'curl -s \"cht.sh/$selected~$query\" | less'"
fi
